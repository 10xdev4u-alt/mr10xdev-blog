---
import BaseLayout from '../layouts/BaseLayout.astro';

const baseUrl = import.meta.env.BASE_URL;

const shelves = [
  {
    title: 'Currently reading',
    books: [
      { title: 'Designing Data-Intensive Applications', author: 'Martin Kleppmann', note: 'Re-read. Still the best book on data systems.' },
    ],
  },
  {
    title: 'Recently finished',
    books: [
      { title: 'The Pragmatic Programmer', author: 'David Thomas, Andrew Hunt', note: '20th anniversary edition. Worth the re-read.' },
      { title: 'Designing Web APIs', author: 'Brenda Jin, Saurabh Sahni, Amir Shevat', note: 'Pragmatic guide to API design.' },
    ],
  },
  {
    title: 'On the queue',
    books: [
      { title: 'Crafting Interpreters', author: 'Robert Nystrom', note: 'I want to write a small language.' },
      { title: 'Database Internals', author: 'Alex Petrov', note: 'Deep dive into storage engines.' },
      { title: 'Software Engineering at Google', author: 'Titus Winters et al.', note: 'Lessons from one of the largest codebases.' },
    ],
  },
];
---

<BaseLayout
  title="Bookshelf"
  description="What I'm reading, what I just finished, what's next."
>
  <section class="hero" style="padding-bottom: 1rem;">
    <div class="container hero-inner">
      <div class="hero-eyebrow fade-up">
        <span class="dot" aria-hidden="true"></span>
        <span>bookshelf · reading list · always growing</span>
      </div>
      <h1 class="fade-up-2">Bookshelf<span style="color: var(--accent);">.</span></h1>
      <p class="hero-lede fade-up-3">
        What I'm reading, what I just finished, what's next.
      </p>
    </div>
  </section>

  <section class="section" style="padding-top: 1rem;">
    <div class="container">
      <div class="prose">
        {shelves.map((shelf) => (
          <div style="margin-bottom: 2.5rem;">
            <h2>{shelf.title}</h2>
            <ul>
              {shelf.books.map((b) => (
                <li>
                  <strong>{b.title}</strong> <span class="muted">by {b.author}</span>
                  {b.note && <span class="dim"> — {b.note}</span>}
                </li>
              ))}
            </ul>
          </div>
        ))}

        <hr />
        <p style="text-align: center;">
          <a href={`${baseUrl}/blog`} class="btn btn-ghost">Read the writing →</a>
        </p>
      </div>
    </div>
  </section>
</BaseLayout>

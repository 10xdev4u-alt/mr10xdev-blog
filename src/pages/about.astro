---
import BaseLayout from '../layouts/BaseLayout.astro';

const baseUrl = import.meta.env.BASE_URL;
---

<BaseLayout
  title="About"
  description="About Mr. 10x Dev — an indie AI builder shipping tools that build tools."
>
  <section class="hero" style="padding-bottom: 1rem;">
    <div class="container hero-inner">
      <div class="hero-eyebrow fade-up">
        <span class="dot" aria-hidden="true"></span>
        <span>about · 10xdev4u-alt · since 2024</span>
      </div>
      <h1 class="fade-up-2">About<span style="color: var(--accent);">.</span></h1>
    </div>
  </section>

  <section class="section" style="padding-top: 1rem;">
    <div class="container">
      <div class="prose">
        <p class="article-lede" style="margin-top: 0;">
          I'm <strong>Princyy</strong> (a.k.a. <em>Mr. 10x Dev</em>), an indie AI
          builder shipping tools that build tools.
        </p>

        <h2>What I work on</h2>
        <p>
          AI infrastructure, developer tools, and GitHub-native workflows. The
          main thing right now is <a href="https://github.com/10xdev4u-alt/gitagent">gitagent</a>
          — an open-source framework for declaring persistent AI agents as files
          in your repo. I ship a lot — usually a few versions a day when I'm in
          build mode.
        </p>

        <h2>How I work</h2>
        <ul>
          <li><strong>Build with AI, then build AI to build.</strong> Every tool I ship is
            meant to make the next tool easier to ship.</li>
          <li><strong>Spec first, code second.</strong> I write the README before the package.json.</li>
          <li><strong>Tests, then more tests.</strong> A green test suite is the only way to
            sleep at night.</li>
          <li><strong>Document the why.</strong> Code shows what; docs show why.</li>
        </ul>

        <h2>Where to find me</h2>
        <ul>
          <li>GitHub: <a href="https://github.com/10xdev4u-alt">@10xdev4u-alt</a></li>
          <li>Email: <a href="mailto:10xdev4u@gmail.com">10xdev4u@gmail.com</a></li>
          <li>Org: <a href="https://github.com/TeamMavericKX">TeamMavericKX</a></li>
        </ul>

        <h2>Brand</h2>
        <p>
          <em>Mr. 10x Dev</em> is my personal brand angle: a builder who ships 10x what an
          average developer ships, by leaning on AI tools + multi-agent systems. It's not
          a flex; it's a methodology.
        </p>

        <hr />

        <p style="text-align: center;">
          <a href={`${baseUrl}/blog`} class="btn btn-ghost">Read the writing →</a>
        </p>
      </div>
    </div>
  </section>
</BaseLayout>

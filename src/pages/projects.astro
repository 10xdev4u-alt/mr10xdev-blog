---
import BaseLayout from '../layouts/BaseLayout.astro';

const baseUrl = import.meta.env.BASE_URL;

const projects = [
  {
    num: '01',
    name: 'gitagent',
    description: 'Open-source framework for declaring persistent, versioned AI agents that live in .github/agents/<name>.md files. 391 tests, 101 commits, MIT licensed.',
    tech: ['TypeScript', 'Hono', 'Octokit', 'Zod', 'Vitest'],
    stars: '01+',
    url: 'https://github.com/10xdev4u-alt/gitagent',
    accent: true,
  },
  {
    num: '02',
    name: 'mr10xdev-blog',
    description: 'This site. A real-world implementation of gitagent: 13 agent manifests in .github/agents/ auto-maintain the blog, the changelog, the link checker, the support router, and more.',
    tech: ['Astro', 'TypeScript', 'MDX', 'GitHub Pages', 'gitagent'],
    stars: '00+',
    url: `${baseUrl}/`,
    accent: true,
  },
  {
    num: '03',
    name: 'parasite',
    description: 'Autonomous agent that wakes up, takes over a codebase, ships a release, and goes back to sleep. Built on top of gitagent.',
    tech: ['TypeScript', 'gitagent', 'Cron', 'Webhooks'],
    stars: '00+',
    url: 'https://github.com/10xdev4u-alt',
    accent: false,
  },
  {
    num: '04',
    name: 'harness',
    description: 'A toolkit for writing agent manifests, validating them, and shipping them to a registry. Like Helm for AI agents.',
    tech: ['TypeScript', 'Zod', 'YAML', 'CLI'],
    stars: '00+',
    url: 'https://github.com/10xdev4u-alt',
    accent: false,
  },
  {
    num: '05',
    name: 'aether-proxy',
    description: 'AI gateway with 26 models, Langfuse tracing, Docker deploy. The gateway I used to build everything else.',
    tech: ['Bun', 'AI Gateway', 'Langfuse', 'Docker'],
    stars: '01+',
    url: 'https://github.com/TeamMavericKX/aether-proxy',
    accent: false,
  },
  {
    num: '06',
    name: 'husk',
    description: 'Minimalist AI agent framework in TypeScript. The experimental precursor to gitagent — kept online for the lesson it taught.',
    tech: ['TypeScript', 'AI', 'Framework', 'npm'],
    stars: '00+',
    url: 'https://github.com/10xdev4u-alt',
    accent: false,
  },
];
---

<BaseLayout
  title="Projects"
  description="Open-source projects in AI agents, dev tools, and the infrastructure that makes them work."
>
  <section class="hero" style="padding-bottom: 1rem;">
    <div class="container hero-inner">
      <div class="hero-eyebrow fade-up">
        <span class="dot" aria-hidden="true"></span>
        <span>{projects.length} projects · MIT licensed · open source</span>
      </div>
      <h1 class="fade-up-2">Projects<span style="color: var(--accent);">.</span></h1>
      <p class="hero-lede fade-up-3">
        Things I've built. AI agents, dev tools, the gateways that route to
        them. Mostly MIT licensed, mostly built in public.
      </p>
    </div>
  </section>

  <section class="section" style="padding-top: 0;">
    <div class="container">
      <div class="projects-grid">
        {projects.map((p) => (
          <a class="project-card" href={p.url} style={p.accent ? 'border-color: var(--border-bright);' : ''}>
            <span class="num">{p.num}</span>
            <h3>{p.name}</h3>
            <p class="desc">{p.description}</p>
            <div style="display: flex; align-items: center; justify-content: space-between; margin-top: 1rem;">
              <div class="tech">
                {p.tech.map((t) => <span>{t}</span>)}
              </div>
              <span class="mono" style="font-size: 0.72rem; color: var(--fg-dim);">★ {p.stars}</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

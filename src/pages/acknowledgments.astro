---
import BaseLayout from '../layouts/BaseLayout.astro';

const baseUrl = import.meta.env.BASE_URL;

const supporters = [
  { name: 'Anthropic', reason: 'For building Claude, the model that powers most of my agents', url: 'https://anthropic.com' },
  { name: 'GitHub', reason: 'For Actions, Pages, and the entire OSS ecosystem', url: 'https://github.com' },
  { name: 'Cloudflare', reason: 'For Workers, R2, and the edge platform that makes global deploys trivial', url: 'https://cloudflare.com' },
  { name: 'Astro', reason: 'For building this very site', url: 'https://astro.build' },
  { name: 'Vitest', reason: 'For the testing framework that makes 391 tests a joy to write', url: 'https://vitest.dev' },
  { name: 'TypeScript', reason: 'For the type system that catches bugs at compile time', url: 'https://typescriptlang.org' },
  { name: 'Bun', reason: 'For the runtime that makes tests 5x faster', url: 'https://bun.sh' },
  { name: 'Zod', reason: 'For the validation library that makes input checking trivial', url: 'https://zod.dev' },
  { name: 'Biome', reason: 'For replacing ESLint + Prettier with one fast tool', url: 'https://biomejs.dev' },
  { name: 'Octokit', reason: 'For the GitHub API client that powers every tool', url: 'https://github.com/octokit' },
  { name: 'Hono', reason: 'For the web framework that powers gitagent', url: 'https://hono.dev' },
  { name: 'Stripe', reason: 'For Press — the gold standard of developer storytelling', url: 'https://stripe.com/press' },
];

const people = [
  { name: 'My family', reason: 'For supporting the indie journey' },
  { name: 'The TeamMavericKX team', reason: 'For being the original community that taught me to ship' },
  { name: 'The 10xdev4u-alt community', reason: 'For the early feedback on every project' },
];
---

<BaseLayout
  title="Acknowledgments"
  description="The open-source projects, tools, and people that made this work possible."
>
  <section class="hero" style="padding-bottom: 1rem;">
    <div class="container hero-inner">
      <div class="hero-eyebrow fade-up">
        <span class="dot" aria-hidden="true"></span>
        <span>acknowledgments · standing on the shoulders of giants</span>
      </div>
      <h1 class="fade-up-2">Acknowledgments<span style="color: var(--accent);">.</span></h1>
      <p class="hero-lede fade-up-3">
        Every project I build stands on the shoulders of giants. Here are
        some of the people, projects, and tools that make the work possible.
      </p>
    </div>
  </section>

  <section class="section" style="padding-top: 1rem;">
    <div class="container">
      <div class="prose">
        <h2>Open source projects</h2>
        <p>
          Every project I build stands on the shoulders of giants. Here are
          some of the OSS projects that power my work:
        </p>
        <ul>
          {supporters.map((s) => (
            <li>
              <strong>{s.name}</strong> — {s.reason}{' '}
              <a href={s.url} rel="noopener">→</a>
            </li>
          ))}
        </ul>

        <h2>People</h2>
        <p>The humans behind the work:</p>
        <ul>
          {people.map((p) => (
            <li><strong>{p.name}</strong> — {p.reason}</li>
          ))}
        </ul>

        <h2>And you</h2>
        <p>
          Thank you for reading. If anything on this site has been useful,
          consider <a href={`${baseUrl}/sponsors`}>sponsoring</a> or{' '}
          <a href="https://github.com/10xdev4u-alt" rel="noopener">starring a repo</a>.
          The work continues because of people like you.
        </p>

        <hr />
        <p style="text-align: center;">
          <a href={`${baseUrl}/`} class="btn btn-ghost">← Back home</a>
        </p>
      </div>
    </div>
  </section>
</BaseLayout>

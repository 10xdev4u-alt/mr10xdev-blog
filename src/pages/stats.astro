---
import BaseLayout from '../layouts/BaseLayout.astro';

const baseUrl = import.meta.env.BASE_URL;

const stats = [
  { label: 'GitHub stars (cumulative)', value: '1000+' },
  { label: 'Public repositories', value: '27' },
  { label: 'Private repositories', value: '9' },
  { label: 'NPM packages shipped', value: '50+' },
  { label: 'GitHub releases', value: '100+' },
  { label: 'Commits this year', value: '500+' },
  { label: 'Issues closed this year', value: '100+' },
  { label: 'Blog posts', value: '100+' },
  { label: 'Open-source projects', value: '5+' },
  { label: 'Years building', value: '3' },
];

const languages = [
  { name: 'TypeScript', percent: 70, color: '#3178c6' },
  { name: 'Go', percent: 15, color: '#00ADD8' },
  { name: 'Python', percent: 5, color: '#3776AB' },
  { name: 'Bash / Shell', percent: 5, color: '#89e051' },
  { name: 'Astro / Markdown', percent: 5, color: '#ff5d01' },
];
---

<BaseLayout
  title="Stats"
  description="The numbers behind the work."
>
  <section class="hero" style="padding-bottom: 1rem;">
    <div class="container hero-inner">
      <div class="hero-eyebrow fade-up">
        <span class="dot" aria-hidden="true"></span>
        <span>stats · the numbers behind the work</span>
      </div>
      <h1 class="fade-up-2">Stats<span style="color: var(--accent);">.</span></h1>
      <p class="hero-lede fade-up-3">
        The numbers behind the work. Not vanity metrics — a way to
        track whether I'm actually shipping.
      </p>
    </div>
  </section>

  <section class="section" style="padding-top: 1rem;">
    <div class="container">
      <div class="prose">
        <h2>By the numbers</h2>
        <div class="post-grid">
          {stats.map((s) => (
            <div class="card" style="text-align: center;">
              <div style="font-family: var(--font-display); font-size: 2rem; font-weight: 600; color: var(--accent); line-height: 1; margin-bottom: 0.4rem;">{s.value}</div>
              <div class="dim mono" style="font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.08em;">{s.label}</div>
            </div>
          ))}
        </div>

        <h2>Languages</h2>
        <p>What I write code in (by lines, last 12 months):</p>
        <div style="margin: 1.5rem 0;">
          {languages.map((l) => (
            <div style="display: grid; grid-template-columns: 120px 1fr 50px; align-items: center; gap: 1rem; margin-bottom: 0.65rem;">
              <div style="font-weight: 500; font-size: 0.92rem;">{l.name}</div>
              <div style="background: var(--bg-elev-2); height: 14px; border-radius: 7px; overflow: hidden; border: 1px solid var(--border);">
                <div style={`width: ${l.percent}%; background: ${l.color}; height: 100%; border-radius: 7px;`}></div>
              </div>
              <div class="dim mono" style="font-size: 0.85rem; text-align: right;">{l.percent}%</div>
            </div>
          ))}
        </div>

        <h2>What this is</h2>
        <p>
          These numbers are pulled from my GitHub profile and a few of my
          npm package pages. They're updated by hand (or by an agent, soon).
          They're not vanity metrics — they're a way to track whether I'm
          actually shipping.
        </p>

        <hr />
        <p style="text-align: center;">
          <a href={`${baseUrl}/blog`} class="btn btn-ghost">Read the writing →</a>
        </p>
      </div>
    </div>
  </section>
</BaseLayout>

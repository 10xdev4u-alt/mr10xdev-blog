---
import BaseLayout from '../layouts/BaseLayout.astro';

const stats = [
  { label: 'GitHub stars (cumulative)', value: '1000+' },
  { label: 'Public repositories', value: '27' },
  { label: 'Private repositories', value: '9' },
  { label: 'NPM packages shipped', value: '50+' },
  { label: 'GitHub releases', value: '100+' },
  { label: 'Commits this year', value: '500+' },
  { label: 'Issues closed this year', value: '100+' },
  { label: 'Blog posts', value: '25+' },
  { label: 'Open-source projects', value: '5+' },
  { label: 'Years building', value: '3' },
];

const languages = [
  { name: 'TypeScript', percent: 70, color: '#3178c6' },
  { name: 'Go', percent: 15, color: '#00ADD8' },
  { name: 'Python', percent: 5, color: '#3776AB' },
  { name: 'Bash / Shell', percent: 5, color: '#89e051' },
  { name: 'Astro / Markdown', percent: 5, color: '#ff5d01' },
];
---

<BaseLayout title="Stats — Mr. 10x Dev">
  <section class="hero">
    <h1>Stats</h1>
    <p>The numbers behind the work.</p>
  </section>

  <section>
    <h2>By the numbers</h2>
    <div class="stats-grid">
      {stats.map((s) => (
        <div class="stat">
          <div class="stat-value">{s.value}</div>
          <div class="stat-label">{s.label}</div>
        </div>
      ))}
    </div>
  </section>

  <section>
    <h2>Languages</h2>
    <p>What I write code in (by lines, last 12 months):</p>
    <div class="language-bars">
      {languages.map((l) => (
        <div class="language-bar">
          <div class="language-name">{l.name}</div>
          <div class="language-track">
            <div class="language-fill" style={`width: ${l.percent}%; background: ${l.color};`}></div>
          </div>
          <div class="language-percent">{l.percent}%</div>
        </div>
      ))}
    </div>
  </section>

  <section>
    <h2>What this is</h2>
    <p>
      These numbers are pulled from my GitHub profile and a few of my
      npm package pages. They're updated by hand (or by an agent, soon).
      They're not vanity metrics — they're a way to track whether I'm
      actually shipping.
    </p>
  </section>
</BaseLayout>

<style>
  .stats-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
    gap: 1rem;
    margin: 1.5rem 0;
  }
  .stat {
    background: var(--bg-elev);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 1rem;
    text-align: center;
  }
  .stat-value {
    font-size: 1.75rem;
    font-weight: 700;
    color: var(--accent);
    margin-bottom: 0.25rem;
  }
  .stat-label {
    font-size: 0.85rem;
    color: var(--fg-muted);
  }
  .language-bars {
    margin: 1.5rem 0;
  }
  .language-bar {
    display: grid;
    grid-template-columns: 100px 1fr 40px;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.5rem;
  }
  .language-name {
    font-weight: 500;
    font-size: 0.9rem;
  }
  .language-track {
    background: var(--bg-elev-2);
    height: 12px;
    border-radius: 6px;
    overflow: hidden;
  }
  .language-fill {
    height: 100%;
    border-radius: 6px;
  }
  .language-percent {
    font-size: 0.85rem;
    color: var(--fg-muted);
    text-align: right;
  }
</style>

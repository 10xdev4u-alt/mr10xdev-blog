---
import BaseLayout from '../layouts/BaseLayout.astro';

const baseUrl = import.meta.env.BASE_URL;
---

<BaseLayout
  title="Uses"
  description="The tools, software, and hardware I use to build."
>
  <section class="hero" style="padding-bottom: 1rem;">
    <div class="container hero-inner">
      <div class="hero-eyebrow fade-up">
        <span class="dot" aria-hidden="true"></span>
        <span>uses · the tools I build with</span>
      </div>
      <h1 class="fade-up-2">Uses<span style="color: var(--accent);">.</span></h1>
      <p class="hero-lede fade-up-3">
        The hardware, software, and services I rely on every day. Updated
        when something changes.
      </p>
    </div>
  </section>

  <section class="section" style="padding-top: 1rem;">
    <div class="container">
      <div class="prose">
        <h2>Hardware</h2>
        <ul>
          <li><strong>MacBook Pro 14" M3 Pro</strong> — 36 GB RAM, 1 TB SSD. Enough headroom for everything.</li>
          <li><strong>External monitor</strong> — 27" 4K, vertical orientation for code review.</li>
          <li><strong>Mechanical keyboard</strong> — for that satisfying click-clack rhythm.</li>
        </ul>

        <h2>Editor</h2>
        <ul>
          <li><strong>VS Code</strong> — primary editor, with Vim mode</li>
          <li><strong>Neovim</strong> — for the rare moments I need a modal editor</li>
          <li><strong>GitHub</strong> — code review, Actions, Pages, Issues. The whole platform.</li>
        </ul>

        <h2>Runtime</h2>
        <ul>
          <li><strong>Bun</strong> — primary runtime, 5x faster than Node for tests</li>
          <li><strong>Node.js</strong> — for production deploys, where Bun isn't supported</li>
          <li><strong>Docker</strong> — for local infra (Postgres, Redis, etc.)</li>
        </ul>

        <h2>AI tools</h2>
        <ul>
          <li><strong>Claude (Sonnet, Haiku, Opus)</strong> — primary model, via Anthropic API</li>
          <li><strong>OpenAI (GPT-4o, o1)</strong> — for benchmarks, evals, and the rare hard case</li>
          <li><strong>Langfuse</strong> — for tracing, evals, observability</li>
        </ul>

        <h2>Productivity</h2>
        <ul>
          <li><strong>Raycast</strong> — launcher, clipboard, snippets, all in one</li>
          <li><strong>Arc</strong> — for browsing the open-source world</li>
          <li><strong>Notion</strong> — for the second brain, the runbooks, the docs</li>
        </ul>

        <hr />
        <p style="text-align: center;">
          <a href={`${baseUrl}/blog`} class="btn btn-ghost">Read the writing →</a>
        </p>
      </div>
    </div>
  </section>
</BaseLayout>

---
/**
 * Search — a simple client-side search component.
 * Indexes all blog posts at build time and searches on input.
 */
import { getCollection } from 'astro:content';

const posts = await getCollection('blog');
const index = posts.map((p) => ({
  slug: p.slug,
  title: p.data.title,
  description: p.data.description,
  tags: p.data.tags ?? [],
  date: p.data.date.toISOString(),
  body: p.body.slice(0, 2000), // First 2K of body for search
}));
---

<form class="search-form" role="search">
  <input
    type="search"
    id="search-input"
    placeholder="Search posts..."
    aria-label="Search posts"
    autocomplete="off"
  />
</form>

<div id="search-results" class="search-results" hidden></div>

<script define:vars={{ index }}>
  const input = document.getElementById('search-input');
  const results = document.getElementById('search-results');

  function search(query) {
    if (!query || query.length < 2) return [];
    const q = query.toLowerCase();
    return index
      .filter((p) =>
        p.title.toLowerCase().includes(q) ||
        p.description.toLowerCase().includes(q) ||
        p.tags.some((t) => t.toLowerCase().includes(q)) ||
        p.body.toLowerCase().includes(q)
      )
      .slice(0, 10);
  }

  function render(matches) {
    if (matches.length === 0) {
      results.innerHTML = '<p class="search-empty">No results.</p>';
      results.hidden = false;
      return;
    }
    results.innerHTML =
      '<ul class="search-list">' +
      matches
        .map(
          (m) =>
            `<li><a href="/blog/${m.slug}/"><strong>${m.title}</strong><br><span>${m.description}</span></a></li>`,
        )
        .join('') +
      '</ul>';
    results.hidden = false;
  }

  let timer;
  input?.addEventListener('input', (e) => {
    clearTimeout(timer);
    timer = setTimeout(() => {
      const q = e.target.value;
      if (q.length < 2) {
        results.hidden = true;
        return;
      }
      render(search(q));
    }, 150);
  });
</script>

<style>
  .search-form {
    margin: 1.5rem 0;
  }
  .search-form input {
    width: 100%;
    padding: 0.75rem 1rem;
    background: var(--bg-elev);
    border: 1px solid var(--border);
    border-radius: 6px;
    color: var(--fg);
    font-size: 0.95rem;
    font-family: inherit;
  }
  .search-form input:focus {
    outline: none;
    border-color: var(--accent);
  }
  .search-results {
    margin-top: 1rem;
  }
  .search-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .search-list li {
    margin-bottom: 0.5rem;
  }
  .search-list a {
    display: block;
    padding: 0.75rem 1rem;
    background: var(--bg-elev);
    border: 1px solid var(--border);
    border-radius: 6px;
    color: inherit;
  }
  .search-list a:hover {
    border-color: var(--accent);
    text-decoration: none;
  }
  .search-list strong {
    color: var(--fg);
  }
  .search-list span {
    color: var(--fg-muted);
    font-size: 0.85rem;
  }
  .search-empty {
    color: var(--fg-muted);
    font-size: 0.9rem;
  }
</style>

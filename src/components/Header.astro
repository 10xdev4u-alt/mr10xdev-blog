---
const baseUrl = import.meta.env.BASE_URL;
const pathname = Astro.url.pathname;

// Strip the baseUrl prefix to compare cleanly
const cleanPath = pathname.startsWith(baseUrl) ? pathname.slice(baseUrl.length) : pathname;
const isActive = (href: string) => {
  const cleanHref = href === '/' ? '/' : href.replace(/\/$/, '');
  const cleanCurrent = cleanPath === '' ? '/' : cleanPath.replace(/\/$/, '');
  if (cleanHref === '/') return cleanCurrent === '/';
  return cleanCurrent === cleanHref || cleanCurrent.startsWith(cleanHref + '/');
};

const nav = [
  { href: `${baseUrl}/`, label: 'Home' },
  { href: `${baseUrl}/blog`, label: 'Writing' },
  { href: `${baseUrl}/projects`, label: 'Projects' },
  { href: `${baseUrl}/now`, label: 'Now' },
  { href: `${baseUrl}/uses`, label: 'Uses' },
  { href: `${baseUrl}/about`, label: 'About' },
];
---

<header class="site-header">
  <div class="container header-inner">
    <a href={`${baseUrl}/`} class="brand" aria-label="Mr. 10x Dev — home">
      <span class="brand-mark" aria-hidden="true">10×</span>
      <span>Mr. 10x Dev</span>
    </a>

    <nav aria-label="Primary">
      <ul>
        {nav.map((item) => (
          <li>
            <a href={item.href} class={isActive(item.href) ? 'active' : ''}>{item.label}</a>
          </li>
        ))}
      </ul>
    </nav>

    <div class="header-actions">
      <span class="header-status" title="Agents online">
        <span class="dot" aria-hidden="true"></span>
        <span>13 agents</span>
      </span>
      <button
        id="theme-toggle"
        class="theme-toggle"
        type="button"
        aria-label="Toggle theme"
        title="Toggle theme"
      >
        <svg class="icon-sun" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="4"/><path d="M12 2v2"/><path d="M12 20v2"/><path d="m4.93 4.93 1.41 1.41"/><path d="m17.66 17.66 1.41 1.41"/><path d="M2 12h2"/><path d="M20 12h2"/><path d="m6.34 17.66-1.41 1.41"/><path d="m19.07 4.93-1.41 1.41"/></svg>
        <svg class="icon-moon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"/></svg>
      </button>
    </div>
  </div>
</header>

<script is:inline>
  (function () {
    const btn = document.getElementById('theme-toggle');
    if (!btn) return;
    btn.addEventListener('click', function () {
      const current = document.documentElement.getAttribute('data-theme') || 'dark';
      const next = current === 'dark' ? 'light' : 'dark';
      document.documentElement.setAttribute('data-theme', next);
      try { localStorage.setItem('theme', next); } catch (_) {}
    });
  })();
</script>

<style>
  .theme-toggle {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    padding: 0;
    background: transparent;
    color: var(--fg-muted);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    cursor: pointer;
    transition: all 0.15s var(--ease-out);
  }
  .theme-toggle:hover {
    color: var(--accent);
    border-color: var(--accent);
  }
  .theme-toggle .icon-sun { display: none; }
  .theme-toggle .icon-moon { display: block; }
  :global([data-theme="light"]) .theme-toggle .icon-sun { display: block; }
  :global([data-theme="light"]) .theme-toggle .icon-moon { display: none; }
</style>

---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

export interface Props {
  title: string;
  description?: string;
  image?: string;
  type?: 'website' | 'article';
  publishedTime?: string;
  author?: string;
  canonical?: string;
  noindex?: boolean;
}

const {
  title,
  description = "Mr. 10x Dev — building open-source AI agents that live in your GitHub repo. Field notes on agent design, deployment, and the future of automation.",
  image,
  type = 'website',
  publishedTime,
  author = '10xdev4u-alt',
  canonical,
  noindex = false,
} = Astro.props;

const siteName = 'Mr. 10x Dev';
const fullTitle = title === siteName ? title : `${title} — ${siteName}`;
const siteUrl = Astro.site?.toString().replace(/\/$/, '') ?? '';
const baseUrl = import.meta.env.BASE_URL;
const canonicalUrl = canonical ?? new URL(Astro.url.pathname, siteUrl + baseUrl).toString();
const ogImage = image
  ? (image.startsWith('http') ? image : `${siteUrl}${baseUrl}${image.startsWith('/') ? image : '/' + image}`)
  : `${siteUrl}${baseUrl}/og-default.png`;
---

<!doctype html>
<html lang="en" data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="generator" content={Astro.generator} />

    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    {noindex && <meta name="robots" content="noindex" />}

    <!-- Open Graph -->
    <meta property="og:type" content={type} />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImage} />
    {publishedTime && <meta property="article:published_time" content={publishedTime} />}
    {author && <meta property="article:author" content={author} />}

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href={`${baseUrl}/favicon.svg`} />

    <!-- Theme bootstrap (avoid flash) -->
    <script is:inline>
      (function () {
        try {
          const stored = localStorage.getItem('theme');
          const prefersLight = window.matchMedia('(prefers-color-scheme: light)').matches;
          const theme = stored ?? (prefersLight ? 'light' : 'dark');
          document.documentElement.setAttribute('data-theme', theme);
        } catch (_) {}
      })();
    </script>

    <!-- Fonts (preconnect + display=swap) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,500;0,9..144,600;0,9..144,700;1,9..144,500;1,9..144,600&family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600&display=swap"
    />

    <!-- RSS -->
    <link rel="alternate" type="application/rss+xml" title={`${siteName} — RSS feed`} href={`${baseUrl}/rss.xml`} />

    <!-- Sitemap -->
    <link rel="sitemap" href={`${baseUrl}/sitemap-index.xml`} />
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>
    <Header />
    <main id="main">
      <slot />
    </main>
    <Footer />

    <style>
      .skip-link {
        position: absolute;
        top: -40px;
        left: 0;
        background: var(--accent);
        color: var(--bg);
        padding: 0.5rem 1rem;
        z-index: 100;
        text-decoration: none;
        font-weight: 600;
        border-radius: 0 0 var(--radius-sm) 0;
      }
      .skip-link:focus { top: 0; }
    </style>
  </body>
</html>
